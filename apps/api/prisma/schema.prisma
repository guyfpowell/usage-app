generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UsageRecord {
  id              Int       @id @default(autoincrement())
  traceId         String?
  userId          String
  requestTime     DateTime
  requestContent  String
  responseContent String
  feedbackValue   String?
  rationale       String?
  toolRoute       String
  ttftSeconds     Float?
  isInternal      Boolean
  hasFeedback     Boolean
  classification  String    @default("To be classified")
  groupText       String?
  ticketText      String?
  jiraIssueKey    String?
  jiraIssueUrl    String?
  epicKey         String?
  linkedIssueKey    String?
  customerResponse  String?
  createdAt         DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, requestTime])
  @@index([toolRoute])
  @@index([isInternal])
  @@index([hasFeedback])
}

model UploadBatch {
  id            Int                 @id @default(autoincrement())
  filename      String
  source        String              @default("csv") // 'csv' | 'databricks'
  insertedCount Int
  updatedCount  Int
  isRolledBack  Boolean             @default(false)
  createdAt     DateTime            @default(now())
  records       UploadBatchRecord[]
}

model UploadBatchRecord {
  id            Int         @id @default(autoincrement())
  batchId       Int
  recordId      Int
  action        String      // 'inserted' | 'updated'
  previousState Json?       // snapshot of ingest fields before update; null for inserts
  batch         UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model InternalDomain {
  id     Int    @id @default(autoincrement())
  domain String @unique
}

model Classification {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)
}
